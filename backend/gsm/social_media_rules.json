{
  "version": "1.0",
  "purpose": "Wykrywanie nazw komunikatorów i platform społecznościowych w polach bilingu GSM (callee, caller, network, service, raw_text, extra).",
  "assumptions": [
    "Operatorzy GSM czasem wpisują nazwy usług (np. 'WhatsApp', 'Viber Out') zamiast numeru telefonu w polu callee/caller.",
    "Rekordy DATA mogą mieć nazwy APN lub usług w polach opisu.",
    "Szukamy case-insensitive, ale unikamy fałszywych trafień (np. 'line' samo w sobie jest zbyt ogólne — wymaga granic słowa).",
    "Każdy wpis ma kategorię i wagę istotności (info/warning) zależną od kontekstu."
  ],
  "search_fields": [
    "callee",
    "caller",
    "network",
    "raw_text",
    "extra.service",
    "extra.description"
  ],
  "categories": {
    "messenger_global": {
      "label": "Komunikatory globalne",
      "severity": "info",
      "platforms": [
        {
          "name": "WhatsApp",
          "patterns": ["whatsapp", "whats app", "whats_app", "wa.me"],
          "regex": "\\bwhats?[_\\s]?app\\b|\\bwa\\.me\\b",
          "note": "Najpopularniejszy komunikator na świecie (3 mld MAU)"
        },
        {
          "name": "Facebook Messenger",
          "patterns": ["messenger", "fb messenger", "facebook messenger"],
          "regex": "\\b(?:facebook\\s*)?messenger\\b|\\bfb\\s*messenger\\b",
          "note": "Komunikator Facebooka (1 mld+ MAU)"
        },
        {
          "name": "Telegram",
          "patterns": ["telegram"],
          "regex": "\\btelegram\\b",
          "note": "Szyfrowany komunikator (1 mld MAU)"
        },
        {
          "name": "Viber",
          "patterns": ["viber", "viber out", "rakuten viber"],
          "regex": "\\bviber\\b|\\brakuten\\s*viber\\b",
          "note": "Popularny w Europie Wschodniej"
        },
        {
          "name": "Signal",
          "patterns": ["signal"],
          "regex": "\\bsignal\\b",
          "note": "Komunikator szyfrowany end-to-end"
        },
        {
          "name": "Skype",
          "patterns": ["skype", "skype out", "skype for business"],
          "regex": "\\bskype\\b",
          "note": "Microsoft — zakończony w 2025"
        },
        {
          "name": "Threema",
          "patterns": ["threema"],
          "regex": "\\bthreema\\b",
          "note": "Szwajcarski szyfrowany komunikator"
        },
        {
          "name": "Wire",
          "patterns": ["wire"],
          "regex": "\\bwire\\b(?!less|frame)",
          "note": "Szyfrowany komunikator korporacyjny"
        },
        {
          "name": "Element (Matrix)",
          "patterns": ["element", "matrix"],
          "regex": "\\belement\\b|\\bmatrix\\.org\\b",
          "note": "Zdecentralizowany protokół komunikacji"
