#!/usr/bin/env bash
# Pre-commit hook: scan staged files for sensitive data patterns
# (IBAN, PESEL, credit card numbers, Polish ID numbers)

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

ERRORS=0

# Get list of staged files (only added/modified, skip deleted)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Skip binary files and known safe patterns
SKIP_PATTERNS="\.sample$|\.png$|\.jpg$|\.jpeg$|\.gif$|\.ico$|\.woff|\.ttf|\.eot"

echo "Scanning staged files for sensitive data..."

for FILE in $STAGED_FILES; do
    # Skip binary/asset files
    if echo "$FILE" | grep -qE "$SKIP_PATTERNS"; then
        continue
    fi

    # Skip if file doesn't exist (renamed/moved)
    if [ ! -f "$FILE" ]; then
        continue
    fi

    # Get staged content (not working copy)
    CONTENT=$(git show ":$FILE" 2>/dev/null)
    if [ -z "$CONTENT" ]; then
        continue
    fi

    # --- Polish IBAN (26 digits, optionally with PL prefix) ---
    # Pattern: PL followed by 26 digits, or standalone 26 digits with typical IBAN grouping
    # Skip: regex patterns in code (containing \d, [0-9], etc.)
    IBAN_HITS=$(echo "$CONTENT" | grep -nP '(?<!\\\d)(?<![\[\\])(?:PL\s*)?(?:\d{2}\s*){1}(?:\d{4}\s*){6}(?!\d)' | grep -vP '\\d|\\s|\[0-9\]|regex|re\.|pattern|PATTERN|_RE\s*=|r"' | head -5)
    if [ -n "$IBAN_HITS" ]; then
        echo -e "${RED}BLOCKED${NC} Possible IBAN number in ${YELLOW}$FILE${NC}:"
        echo "$IBAN_HITS" | head -3
        ERRORS=$((ERRORS + 1))
    fi

    # --- PESEL (11-digit Polish ID number) ---
    # Must be standalone 11 digits (not part of longer number, not in code patterns)
    PESEL_HITS=$(echo "$CONTENT" | grep -nP '(?<!\d)(?<!["\x27])\d{11}(?!\d)' | grep -vP '\\d|regex|re\.|pattern|hash|sha|md5|uuid|timestamp|_id|0{6,}|1{6,}' | head -5)
    if [ -n "$PESEL_HITS" ]; then
        echo -e "${RED}BLOCKED${NC} Possible PESEL number in ${YELLOW}$FILE${NC}:"
        echo "$PESEL_HITS" | head -3
        ERRORS=$((ERRORS + 1))
    fi

    # --- Credit card numbers (16 digits) ---
    CC_HITS=$(echo "$CONTENT" | grep -nP '(?<!\d)\d{4}[\s-]?\d{4}[\s-]?\d{4}[\s-]?\d{4}(?!\d)' | grep -vP '\\d|regex|re\.|pattern|PATTERN|_RE|mask|\*{4}|0{4}|1234' | head -5)
    if [ -n "$CC_HITS" ]; then
        echo -e "${RED}BLOCKED${NC} Possible credit card number in ${YELLOW}$FILE${NC}:"
        echo "$CC_HITS" | head -3
        ERRORS=$((ERRORS + 1))
    fi

    # --- Email addresses (real ones, not example.com) ---
    EMAIL_HITS=$(echo "$CONTENT" | grep -nP '[a-zA-Z0-9._%+-]+@(?!example\.com|test\.com|localhost|noreply)[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}' | grep -vP 'regex|re\.|pattern|@anthropic|@github|placeholder|schema|validator|RFC|spec' | head -5)
    if [ -n "$EMAIL_HITS" ]; then
        echo -e "${YELLOW}WARNING${NC} Possible real email address in ${YELLOW}$FILE${NC}:"
        echo "$EMAIL_HITS" | head -3
        # Emails are warning only, don't block
    fi

    # --- Phone numbers (Polish: 9 digits, optionally with +48) ---
    PHONE_HITS=$(echo "$CONTENT" | grep -nP '(?<!\d)(?:\+48[\s-]?)?\d{3}[\s-]?\d{3}[\s-]?\d{3}(?!\d)' | grep -vP '\\d|regex|re\.|pattern|PATTERN|000|111|123|example|test|mock' | head -5)
    if [ -n "$PHONE_HITS" ]; then
        echo -e "${YELLOW}WARNING${NC} Possible phone number in ${YELLOW}$FILE${NC}:"
        echo "$PHONE_HITS" | head -3
        # Phone numbers are warning only
    fi

    # --- Blocked file types that slipped through .gitignore ---
    if echo "$FILE" | grep -qiE '\.(pdf|db|sqlite|sqlite3|env|key|pem|p12|pfx|log)$'; then
        echo -e "${RED}BLOCKED${NC} Sensitive file type: ${YELLOW}$FILE${NC}"
        ERRORS=$((ERRORS + 1))
    fi
done

if [ $ERRORS -gt 0 ]; then
    echo ""
    echo -e "${RED}Commit BLOCKED: found $ERRORS potential sensitive data issue(s).${NC}"
    echo -e "If these are false positives (e.g. regex patterns in code), use:"
    echo -e "  ${YELLOW}git commit --no-verify${NC}"
    echo ""
    exit 1
fi

echo "No sensitive data detected. Proceeding with commit."
exit 0
